# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mamas_kitchen?schema=public"

# JWT for admin auth (use a long random string in production)
JWT_SECRET="your-secret-key-change-in-production"

# PayHere Sri Lanka
